// OpenClaw 推荐配置示例
// 此配置文件包含常用的设置选项，可根据个人需求进行调整
// 完整配置参考：https://docs.openclaw.ai/gateway/configuration
{
  "agents": { // 代理配置
    "defaults": { // 所有代理的默认设置
      "model": { // 模型配置
        "primary": "dashscope/qwen3.5-plus" // 默认主模型
      },
      "thinkingLevel": "medium", // 思考级别：off|minimal|low|medium|high|xhigh
      "verboseLevel": "off", // 详细程度：on|off
      "usage": "tokens", // 使用统计：off|tokens|full
      "sendPolicy": "reply", // 发送策略：reply|reply-back|forward
      "groupActivation": "mention", // 群组激活：mention|always
      "workspace": "~/.openclaw/workspace", // 工作区路径
      "sandbox": {
        "mode": "non-main" // 非主会话的沙箱模式：off|non-main|all
      },
      "subagents": { // 子代理配置
        "allowAgents": ["*"], // 允许的代理ID，"*"表示允许所有
        "maxConcurrent": 3, // 最大并发子代理数
        "maxSpawnDepth": 2, // 最大子代理嵌套深度
        "maxChildrenPerAgent": 5, // 每个代理最大子代理数
        "archiveAfterMinutes": 60, // 子代理会话自动归档时间
        "model": {
          "primary": "dashscope/qwen3.5-plus" // 子代理默认模型
        },
        "thinking": "medium", // 子代理思考级别
        "runTimeoutSeconds": 300 // 子代理运行超时时间
      },
      "memorySearch": { // 记忆搜索配置
        "enabled": true, // 是否启用记忆搜索
        "retention": "1d", // 记忆保留时间
        "maxResults": 5 // 最大返回结果数
      },
      "humanDelay": { // 人类回复延迟配置
        "enabled": true, // 是否启用
        "min": 500, // 最小延迟（毫秒）
        "max": 2000 // 最大延迟（毫秒）
      },
      "heartbeat": { // 心跳配置
        "every": "30m", // 心跳间隔
        "activeHours": { // 心跳活跃时间窗口
          "start": "08:00", // 开始时间
          "end": "22:00" // 结束时间
        }
      },
      "maxConcurrent": 3, // 最大并发代理数
      "compaction": { // 会话压缩配置
        "mode": "safeguard", // 压缩模式：safeguard|aggressive
        "reserveTokens": 10000, // 压缩前保留的令牌数
        "keepRecentTokens": 50000, // 保留的最近令牌数
        "reserveTokensFloor": 5000, // 强制保留的最小令牌数
        "maxHistoryShare": 0.5, // 历史记录在上下文窗口中的最大比例
        "maxTokens": 100000 // 最大令牌数
      },
      "contextPruning": { // 上下文修剪配置
        "mode": "cache-ttl", // 修剪模式：cache-ttl|size
        "ttl": "1h", // 缓存有效期
        "keepLastAssistants": 3, // 保留的最近助手回复数
        "softTrimRatio": 0.8, // 软修剪比例
        "hardClearRatio": 0.9 // 硬清理比例
      }
    },
    "list": [ // 代理列表
      {
        "id": "main", // 代理ID
        "default": true, // 是否为默认代理
        "name": "Main Assistant", // 代理名称
        "workspace": "~/.openclaw/workspace-main", // 主agent工作区
        "model": {
          "primary": "dashscope/qwen3.5-plus" // 主模型
        },
        "identity": { // 代理身份配置
          "name": "Main Assistant", // 身份名称
          "role": "AI assistant for general tasks and canvas operations" // 身份角色
        },
        "groupChat": { // 群组聊天配置
          "mentionRequired": true, // 是否需要@提及
          "replyAll": false // 是否回复所有人
        },
        "tools": { // 工具配置
          "profile": "full", // 工具配置文件：full|coding|messaging
          "allow": ["group:fs", "group:runtime", "browser", "canvas", "nodes"], // 允许的工具
          "deny": ["system"] // 禁止的工具
        },
        "params": { // 模型参数
          "temperature": 0.7, // 温度参数，控制生成文本的随机性
          "cacheRetention": "short", // 缓存保留时间
          "maxOutputTokens": 4096 // 最大输出令牌数
        }
      },
      {
        "id": "work", // 代理ID
        "name": "Work Assistant", // 代理名称
        "workspace": "~/.openclaw/workspace-work", // 工作agent工作区
        "model": {
          "primary": "anthropic/claude-opus-4-6" // 主模型
        },
        "identity": { // 代理身份配置
          "name": "Work Assistant", // 身份名称
          "role": "AI assistant specialized in coding and project management" // 身份角色
        },
        "groupChat": { // 群组聊天配置
          "mentionRequired": true, // 是否需要@提及
          "replyAll": false // 是否回复所有人
        },
        "tools": { // 工具配置
          "profile": "coding", // 工具配置文件：full|coding|messaging
          "allow": ["group:fs", "group:runtime", "browser", "git", "npm"], // 允许的工具
          "deny": ["system"] // 禁止的工具
        },
        "params": { // 模型参数
          "temperature": 0.5, // 温度参数，控制生成文本的随机性
          "cacheRetention": "short", // 缓存保留时间
          "maxOutputTokens": 8192 // 最大输出令牌数
        }
      },
      {
        "id": "personal", // 代理ID
        "name": "Personal Assistant", // 代理名称
        "workspace": "~/.openclaw/workspace-personal", // 个人agent工作区
        "model": {
          "primary": "dashscope/qwen3.5-plus" // 主模型
        },
        "identity": { // 代理身份配置
          "name": "Personal Assistant", // 身份名称
          "role": "AI assistant for personal tasks and messaging" // 身份角色
        },
        "groupChat": { // 群组聊天配置
          "mentionRequired": true, // 是否需要@提及
          "replyAll": false // 是否回复所有人
        },
        "tools": { // 工具配置
          "profile": "messaging", // 工具配置文件：full|coding|messaging
          "allow": ["group:fs", "sessions_list"], // 允许的工具
          "deny": ["system"] // 禁止的工具
        },
        "params": { // 模型参数
          "temperature": 0.8, // 温度参数，控制生成文本的随机性
          "cacheRetention": "short", // 缓存保留时间
          "maxOutputTokens": 4096 // 最大输出令牌数
        }
      }
    ]
  },
  "bindings": [ // 渠道绑定配置，将特定渠道和用户绑定到指定代理
    {
      "agentId": "main", // 目标代理ID
      "match": { "channel": "feishu", "peer": { "kind": "direct", "id": "ou_1234567" } } // 匹配条件：飞书直接消息
    },
    {
      "agentId": "personal", // 目标代理ID
      "match": { "channel": "whatsapp", "peer": { "kind": "direct", "id": "+1234567890" } } // 匹配条件：WhatsApp直接消息
    },
    {
      "agentId": "work", // 目标代理ID
      "match": { "channel": "telegram", "peer": { "kind": "direct", "id": "123456789" } } // 匹配条件：Telegram直接消息
    },
    {
      "agentId": "main", // 目标代理ID
      "match": { "channel": "discord", "peer": { "kind": "direct", "id": "123456789012345678" } } // 匹配条件：Discord直接消息
    }
  ],
  "routing": { // 路由配置，设置不同渠道的默认代理
    "channels": {
      "feishu": "main", // 飞书默认使用main代理
      "whatsapp": "personal", // WhatsApp默认使用personal代理
      "telegram": "work", // Telegram默认使用work代理
      "discord": "main" // Discord默认使用main代理
    }
  },
  "gateway": { // 网关配置
    "port": 18789, // 网关端口
    "mode": "local", // 网关模式：local
    "bind": "loopback", // 绑定地址：loopback|all
    "controlUi": { // 控制UI配置
      "allowInsecureAuth": false // 禁用不安全的认证
    },
    "auth": { // 认证配置
      "mode": "token", // 认证模式：token
      "token": "" // 认证令牌
    },
    "tailscale": { // Tailscale配置
      "mode": "off", // Tailscale模式：off|serve|funnel
      "resetOnExit": false // 退出时重置Tailscale配置
    }
  },
  "browser": { // 浏览器配置
    "enabled": true, // 是否启用浏览器
    "headless": true, // 是否以无头模式运行
    "noSandbox": true, // 是否禁用沙箱
    "defaultProfile": "clawd", // 默认浏览器配置文件
    "profiles": { // 浏览器配置文件列表
      "clawd": { // 配置文件名称
        "cdpPort": 18800, // Chrome DevTools Protocol端口
        "color": "#FF4500" // 配置文件颜色
      }
    }
  },
  "canvas": { // Canvas配置
    "enabled": true // 是否启用Canvas
  },
  "channels": { // 渠道配置
    "feishu": { // 飞书配置
      "enabled": true, // 是否启用飞书
      "dmPolicy": "pairing", // DM策略：open|pairing
      "webhookPath": "/webhook/feishu", // Webhook路径
      "allowFrom": ["ou_12345f"], // 允许的用户/部门ID
      "accounts": {
        "main": {
          "appId": "", // 飞书应用ID
          "appSecret": "", // 飞书应用密钥
          "verifyToken": "YOUR_FEISHU_VERIFY_TOKEN", // 飞书验证令牌
          "encryptKey": "YOUR_FEISHU_ENCRYPT_KEY", // 飞书加密密钥
          "botName": "OpenClaw" // 机器人名称
        }
      }
    },
    "whatsapp": { // WhatsApp配置
      "enabled": true, // 是否启用WhatsApp
      "allowFrom": ["+1234567890", "+0987654321"], // 允许的发送者
      "groups": ["*"] // 允许的群组（"*"表示所有群组）
    },
    "telegram": { // Telegram配置
      "enabled": true, // 是否启用Telegram
      "botToken": "YOUR_TELEGRAM_BOT_TOKEN", // Telegram机器人令牌
      "allowFrom": ["123456789"], // 允许的用户ID
      "groups": {
        "*": {
          "requireMention": true // 群组中需要@机器人
        }
      },
      "dmPolicy": "pairing" // DM策略：open|pairing
    },
    "slack": { // Slack配置
      "enabled": true, // 是否启用Slack
      "botToken": "YOUR_SLACK_BOT_TOKEN", // Slack机器人令牌
      "appToken": "YOUR_SLACK_APP_TOKEN", // Slack应用令牌
      "allowFrom": ["U123456789"], // 允许的用户ID
      "dmPolicy": "pairing" // DM策略：open|pairing
    },
    "discord": { // Discord配置
      "enabled": true, // 是否启用Discord
      "token": "YOUR_DISCORD_BOT_TOKEN", // Discord机器人令牌
      "allowFrom": ["123456789012345678"], // 允许的用户ID
      "dmPolicy": "pairing", // DM策略：open|pairing
      "commands": {
        "native": true, // 启用原生命令
        "text": true // 启用文本命令
      }
    },
    "signal": { // Signal配置
      "enabled": false, // 是否启用Signal（需要signal-cli）
      "account": "+1234567890" // Signal账号
    },
    "bluebubbles": { // BlueBubbles配置（iMessage）
      "enabled": false, // 是否启用BlueBubbles
      "serverUrl": "http://localhost:1234", // BlueBubbles服务器URL
      "password": "your-bluebubbles-password", // BlueBubbles密码
      "webhookPath": "/webhook/bluebubbles" // Webhook路径
    },
    "webchat": { // WebChat配置
      "enabled": true // 是否启用WebChat
    }
  },
  "nodes": { // 节点配置
    "enabled": true, // 是否启用节点
    "allowFrom": ["*"] // 允许的节点，"*"表示允许所有
  },
  "cron": { // 定时任务配置
    "enabled": true, // 是否启用定时任务
    "tasks": [ // 定时任务列表
      {
        "name": "daily-check", // 任务名称
        "schedule": "0 9 * * *", // 任务调度（cron表达式）：每天上午9点
        "command": "agent", // 要执行的命令
        "args": ["--message", "What's on my agenda today?"] // 命令参数
      }
    ]
  },
  "skills": { // 技能配置
    "enabled": true, // 是否启用技能
    "clawhub": { // ClawHub技能配置
      "enabled": true // 是否启用ClawHub
    }
  },
  "logging": { // 日志配置
    "level": "info", // 日志级别：debug|info|warn|error
    "redact": true, // 是否启用日志敏感信息 redaction
    "file": "~/.openclaw/logs/openclaw.log", // 日志文件路径
    "maxFileSize": 10485760, // 最大文件大小（10MB）
    "maxFiles": 5 // 最大日志文件数
  },
  "media": { // 媒体配置
    "maxSizeMb": 25, // 媒体文件最大大小（MB）
    "tempDir": "~/.openclaw/temp" // 临时目录
  },
  "auth": { // 认证配置
    "profiles": { // 认证配置文件
      "dashscope:default": { // 达摩院默认配置
        "provider": "dashscope", // 提供商
        "mode": "api_key", // 认证模式
        "key": "YOUR_DASHSCOPE_API_KEY" // API密钥
      },
      "anthropic:default": { // Anthropic默认配置
        "provider": "anthropic", // 提供商
        "mode": "api_key", // 认证模式
        "key": "YOUR_DASHSCOPE_API_KEY" // API密钥
      }
    },
    "order": { // 认证顺序
      "anthropic": ["anthropic:default"], // Anthropic认证顺序
      "dashscope": ["dashscope:default"] // 达摩院认证顺序
    }
  },
  "models": { // 模型配置
    "mode": "merge", // 模型模式：merge|override
    "providers": { // 模型提供商
      "dashscope": { // 达摩院提供商
        "baseUrl": "https://dashscope.aliyuncs.com/compatible-mode/v1", // API基础URL
        "api": "openai-completions", // API类型
        "models": [ // 模型列表
          {
            "id": "qwen3.5-plus", // 模型ID
            "name": "Qwen3.5 Plus", // 模型名称
            "reasoning": true, // 是否支持推理
            "contextWindow": 983616, // 上下文窗口大小
            "maxTokens": 65536, // 最大令牌数
            "compat": { // 兼容性信息
              "supportsDeveloperRole": false, // 是否支持开发者角色
              "supportsReasoningEffort": false // 是否支持推理努力
            }
          },
          {
            "id": "qwen3-max-2026-01-23", // 模型ID
            "name": "Qwen3 Max Thinking", // 模型名称
            "reasoning": true, // 是否支持推理
            "contextWindow": 262144, // 上下文窗口大小
            "maxTokens": 32768, // 最大令牌数
            "compat": { // 兼容性信息
              "supportsDeveloperRole": false, // 是否支持开发者角色
              "supportsReasoningEffort": false // 是否支持推理努力
            }
          },
          {
            "id": "qwen3-coder-plus", // 模型ID
            "name": "Qwen3 Coder Plus", // 模型名称
            "contextWindow": 1000000, // 上下文窗口大小
            "maxTokens": 65536 // 最大令牌数
          }
        ]
      },
      "anthropic": {
        "models": [
          {
            "id": "claude-opus-4-6",
            "name": "Claude Opus",
            "reasoning": true,
            "contextWindow": 200000,
            "maxTokens": 4096
          }
        ]
      }
    }
  },
  "network": { // 网络配置
    "timeout": 30, // 网络超时时间（秒）
    "retry": { // 重试配置
      "count": 3, // 重试次数
      "delay": 1000 // 重试延迟（毫秒）
    }
  },
  "tools": { // 工具配置
    "fs": { // 文件系统工具配置
      "workspaceOnly": true // 是否限制文件系统工具只访问工作区目录
    },
    "agentToAgent": { // 代理间访问控制
      "allow": ["main", "work", "personal"] // 允许相互访问的代理ID
    }
  },
  "commands": { // 命令配置
    "native": "auto", // 原生命令处理方式：auto|on|off
    "nativeSkills": "auto", // 原生技能处理方式：auto|on|off
    "restart": true, // 是否允许重启命令
    "ownerDisplay": "raw" // 所有者信息显示方式：raw|name|none
  },
  "session": { // 会话配置
    "dmScope": "per-channel-peer" // 直接消息会话范围：per-channel-peer|per-channel|global
  }
}
