{
  "agents": {
    "defaults": {
      "model": {
        "primary": "dashscope/qwen3.5-plus",
        "fallbacks": ["dashscope/qwen3-max-2026-01-23"]
      },
      "workspace": "~/.openclaw/workspace",
      "imageModel": {
        "primary": "dashscope/qwen3.5-plus"
      },
      "models": {
        "dashscope/qwen3.5-plus": { "alias": "qwen3.5-plus" },
        "dashscope/qwen3-max-2026-01-23": { "alias": "qwen3-max" },
        "dashscope/qwen3-coder-plus": { "alias": "qwen3-coder-plus" }
      },
      "thinkingDefault": "low",
      "verboseDefault": "off",
      "elevatedDefault": "on",
      "blockStreamingDefault": "off",
      "blockStreamingBreak": "text_end",
      "blockStreamingChunk": {
        "minChars": 800,
        "maxChars": 1200,
        "breakPreference": "paragraph"
      },
      "blockStreamingCoalesce": {
        "idleMs": 1000
      },
      "humanDelay": {
        "mode": "natural"
      },
      "timeoutSeconds": 600,
      "mediaMaxMb": 5,
      "typingIntervalSeconds": 5,
      "maxConcurrent": 3,
      "heartbeat": {
        "every": "30m",
        "activeHours": {
          "start": "08:00",
          "end": "22:00"
        }
      },
      "memorySearch": {
        "provider": "openai",
        "model": "text-embedding-v4",
        "remote": {
          "baseUrl": "https://dashscope.aliyuncs.com/api/v2/apps/protocols/compatible-mode/v1",
          "apiKey": "${env:DASHSCOPE_API_KEY}",
          "api": "openai-responses"
        },
        "extraPaths": ["../team-docs", "/srv/shared-notes"]
      },
      "sandbox": {
        "mode": "non-main",
        "workspaceRoot": "~/.openclaw/sandboxes",
        "scope": "agent",
        "docker": {
          "image": "openclaw-sandbox:bookworm-slim",
          "workdir": "/workspace",
          "readOnlyRoot": true,
          "tmpfs": ["/tmp", "/var/tmp", "/run"],
          "network": "none",
          "user": "1000:1000"
        }
      }
    },
    "list": [
      {
        "id": "main",
        "default": true,
        "name": "Main Assistant",
        "tools": {
          "profile": "full",
          "allow": ["group:fs", "group:runtime", "browser", "canvas", "nodes"],
          "deny": ["system"],
          "fs": {
            "workspaceOnly": false
          }
        }
      },
      {
        "id": "work",
        "name": "Work Assistant",
        "workspace": "~/.openclaw/workspace-work",
        "model": {
          "primary": "dashscope/qwen3-coder-plus"
        },
        "tools": {
          "profile": "coding",
          "allow": ["group:fs", "group:runtime", "browser", "git", "pnpm"],
          "deny": ["system"]
        }
      },
      {
        "id": "personal",
        "name": "Personal Assistant",
        "workspace": "~/.openclaw/workspace-personal",
        "tools": {
          "profile": "messaging",
          "allow": ["group:fs", "sessions_list"],
          "deny": ["system"]
        }
      }
    ]
  },
  "bindings": [
    {
      "agentId": "main",
      "match": {
        "channel": "feishu",
        "peer": { "kind": "direct", "id": "ou_1234567" }
      }
    },
    {
      "agentId": "personal",
      "match": {
        "channel": "whatsapp",
        "peer": { "kind": "direct", "id": "+1234567890" }
      }
    },
    {
      "agentId": "work",
      "match": {
        "channel": "telegram",
        "peer": { "kind": "direct", "id": "123456789" }
      }
    },
    {
      "agentId": "main",
      "match": {
        "channel": "discord",
        "peer": { "kind": "direct", "id": "123456789012345678" }
      }
    }
  ],
  "gateway": {
    "port": 18789,
    "mode": "local",
    "bind": "loopback",
    "trustedProxies": [],
    "controlUi": {
      "enabled": true,
      "basePath": "/openclaw"
    },
    "auth": {
      "mode": "token",
      "token": "YOUR_STRONG_GATEWAY_TOKEN_HERE",
      "allowTailscale": true
    },
    "tailscale": {
      "mode": "off",
      "resetOnExit": false
    }
  },
  "channels": {
    "feishu": {
      "enabled": true,
      "dmPolicy": "pairing",
      "allowFrom": ["ou_1234567"],
      "accounts": {
        "default": {
          "appId": "${env:FEISHU_APP_ID}",
          "appSecret": "${env:FEISHU_APP_SECRET}",
          "botName": "小螃蟹"
        }
      }
    },
    "whatsapp": {
      "enabled": false,
      "allowFrom": ["+1234567890", "+0987654321"],
      "groups": { "*": { "requireMention": true } }
    },
    "telegram": {
      "enabled": false,
      "botToken": "${env:TELEGRAM_BOT_TOKEN}",
      "allowFrom": ["123456789"],
      "groups": {
        "*": {
          "requireMention": true
        }
      },
      "dmPolicy": "pairing"
    },
    "discord": {
      "enabled": false,
      "token": "${env:DISCORD_BOT_TOKEN}",
      "allowFrom": ["123456789012345678"],
      "dmPolicy": "pairing"
    },
    "signal": {
      "enabled": false,
      "account": "+1234567890"
    }
  },
  "skills": {
    "allowBundled": ["weather", "summarize", "github", "healthcheck"],
    "load": {
      "extraDirs": ["~/Projects/agent-scripts/skills"]
    },
    "install": {
      "preferBrew": false,
      "nodeManager": "pnpm"
    },
    "entries": {
      "weather": {
        "enabled": true
      },
      "summarize": {
        "enabled": true
      },
      "github": {
        "enabled": true
      },
      "healthcheck": {
        "enabled": true
      }
    }
  },
  "auth": {
    "profiles": {
      "dashscope:default": {
        "provider": "dashscope",
        "mode": "api_key"
      },
      "anthropic:default": {
        "provider": "anthropic",
        "mode": "api_key"
      }
    },
    "order": {
      "anthropic": ["anthropic:default"],
      "dashscope": ["dashscope:default"]
    }
  },
  "models": {
    "mode": "merge",
    "providers": {
      "dashscope": {
        "baseUrl": "https://dashscope.aliyuncs.com/api/v2/apps/protocols/compatible-mode/v1",
        "apiKey": "${env:DASHSCOPE_API_KEY}",
        "api": "openai-responses",
        "models": [
          {
            "id": "qwen3.5-plus",
            "name": "Qwen3.5 Plus",
            "reasoning": true,
            "contextWindow": 983616,
            "maxTokens": 65536,
            "compat": {
              "supportsDeveloperRole": false,
              "supportsReasoningEffort": false
            }
          },
          {
            "id": "qwen3-max-2026-01-23",
            "name": "Qwen3 Max Thinking",
            "reasoning": true,
            "contextWindow": 262144,
            "maxTokens": 32768,
            "compat": {
              "supportsDeveloperRole": false,
              "supportsReasoningEffort": false
            }
          },
          {
            "id": "qwen3-coder-plus",
            "name": "Qwen3 Coder Plus",
            "contextWindow": 1000000,
            "maxTokens": 65536
          }
        ]
      },
      "anthropic": {
        "baseUrl": "https://api.anthropic.com/v1",
        "apiKey": "${env:ANTHROPIC_API_KEY}",
        "models": [
          {
            "id": "claude-opus-4-6",
            "name": "Claude Opus",
            "reasoning": true,
            "contextWindow": 200000,
            "maxTokens": 4096
          }
        ]
      }
    }
  },
  "commands": {
    "native": "auto",
    "nativeSkills": "auto",
    "restart": true,
    "ownerDisplay": "raw"
  },
  "session": {
    "scope": "per-sender",
    "reset": {
      "mode": "daily",
      "atHour": 4,
      "idleMinutes": 60
    },
    "resetByChannel": {
      "discord": {
        "mode": "idle",
        "idleMinutes": 10080
      }
    },
    "resetTriggers": ["/new", "/reset"]
  },
  "cron": {
    "enabled": true,
    "maxConcurrentRuns": 2,
    "sessionRetention": "24h",
    "runLog": {
      "maxBytes": "2mb",
      "keepLines": 2000
    }
  },
  "secrets": {
    "providers": {
      "default": {
        "source": "env"
      }
    },
    "defaults": {
      "env": "default"
    }
  },
  "logging": {
    "level": "info",
    "consoleLevel": "info",
    "consoleStyle": "pretty",
    "redactSensitive": "tools"
  },
  "tools": {
    "fs": {
      "workspaceOnly": true
    },
    "agentToAgent": {
      "allow": ["main", "work", "personal"]
    },
    "sessions": {
      "visibility": "all"
    },
    "web": {
      "search": {
        "enabled": false
      }
    }
  }
}
